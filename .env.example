# Where the Esus BaaS API lives. Production: https://api.esus.health
# Local dev (running the api repo on :3000): http://localhost:3000
ESUS_API_URL=https://api.esus.health

# The public id of the tenant app you registered in the Esus console.
# Find it on /apps/<id> "Overview" tab → "Public ID".
# Format: app_<32 hex chars>.
ESUS_APP_ID=app_replace_me_with_real_public_id

# Machine-to-machine API key for the same tenant app. Used by the
# server-side FHIR helper (lib/fhir.ts) to list Patients / Practitioners.
# Generate one in the Esus console → Apps → <your app> → API keys.
# The secret is shown ONCE at creation / rotation — store it here.
ESUS_API_KEY_ID=
ESUS_API_KEY_SECRET=

# Optional. If your app uses Cloudflare Turnstile on the signup form,
# expose the site key here. Leave unset for local dev (no captcha).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
